.DS_Store
.claude/
scripts/__pycache__/
*.zip
*.wav
*.ckpt
txt.txt
*_sliced/

# Keep the repo lightweight; store heavy artifacts locally.
tools/DiffSinger/*
!tools/DiffSinger/.gitkeep
tools/MakeDiffSinger/*
!tools/MakeDiffSinger/.gitkeep
tools/SOME/*
!tools/SOME/.gitkeep
tools/audio-slicer/*
!tools/audio-slicer/.gitkeep

# Datasets — only track the example_singer template
datasets/*
!datasets/example_singer/

# Pretrained models
models/vocoder/*
!models/vocoder/.gitkeep
models/some/*
!models/some/.gitkeep
models/acoustic/*
!models/acoustic/.gitkeep
models/variance/*
!models/variance/.gitkeep

# Experiments / checkpoints
experiments/*/
!experiments/.gitkeep

# Renders
renders/*
!renders/.gitkeep
!renders/demos/
!renders/ab-tests/
renders/demos/*
!renders/demos/.gitkeep
renders/ab-tests/*
!renders/ab-tests/.gitkeep

# Staging area
staging/*
!staging/.gitkeep
